      "description": "分布式锁类型，可选值：redis、zookeeper",
      "sourceType": "com.mycorp.distributedlock.springboot.config.DistributedLockProperties",
      "defaultValue": "redis",
      "validation": {
        "allowedValues": ["redis", "zookeeper"]
      }
    },
    {
      "name": "spring.distributed-lock.default-lease-time",
      "type": "java.time.Duration",
