{
  "dashboard": {
    "title": "Distributed Lock Overview",
    "tags": ["distributed-lock", "performance", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Lock Operations Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(distributed_lock_operations_total[5m])",
            "legendFormat": "{{operation}} - {{result}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "unit": "ops",
            "min": 0
          },
          {
            "unit": "short"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Lock Acquisition Time",
        "type": "heatmap",
        "targets": [
          {
            "expr": "rate(distributed_lock_acquisition_duration_seconds_bucket[5m])",
            "legendFormat": "{{le}}",
            "refId": "A"
          }
        ],
        "yAxis": {
          "unit": "s"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Active Locks",
        "type": "singlestat",
        "targets": [
          {
            "expr": "distributed_lock_active_count",
            "refId": "A"
          }
        ],
        "format": "none",
        "colorBackground": true,
        "thresholds": "50,100",
        "colors": ["green", "orange", "red"],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "singlestat",
        "targets": [
          {
            "expr": "rate(distributed_lock_operations_total{result='failure'}[5m]) / rate(distributed_lock_operations_total[5m]) * 100",
            "refId": "A"
          }
        ],
        "format": "percent",
        "colorBackground": true,
        "thresholds": "5,10",
        "colors": ["green", "orange", "red"],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Connection Pool Status",
        "type": "table",
        "targets": [
          {
            "expr": "distributed_lock_connection_pool_active",
            "legendFormat": "Active Connections",
            "refId": "A"
          },
          {
            "expr": "distributed_lock_connection_pool_idle",
            "legendFormat": "Idle Connections",
            "refId": "B"
          },
          {
            "expr": "distributed_lock_connection_pool_waiting",
            "legendFormat": "Waiting Threads",
            "refId": "C"
          }
        ],
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "JVM Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{area='heap'}",
            "legendFormat": "Heap Used",
            "refId": "A"
          },
          {
            "expr": "jvm_memory_committed_bytes{area='heap'}",
            "legendFormat": "Heap Committed",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "unit": "bytes",
            "min": 0
          },
          {
            "unit": "short"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 14
        }
      },
      {
        "id": 7,
        "title": "GC Performance",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(jvm_gc_pause_seconds_sum[5m]) / rate(jvm_gc_pause_seconds_count[5m])",
            "legendFormat": "Avg GC Pause",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "unit": "s",
            "min": 0
          },
          {
            "unit": "short"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 14
        }
      },
      {
        "id": 8,
        "title": "System Resources",
        "type": "graph",
        "targets": [
          {
            "expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
            "legendFormat": "CPU Usage %",
            "refId": "A"
          },
          {
            "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
            "legendFormat": "Memory Usage %",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "unit": "percent",
            "min": 0,
            "max": 100
          },
          {
            "unit": "short"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 22
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "templating": {
      "list": [
        {
          "name": "instance",
          "type": "query",
          "query": "label_values(distributed_lock_operations_total, instance)",
          "label": "Instance",
          "multi": true,
          "includeAll": true
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "prometheus",
          "expr": "up{job='distributed-lock-app'} == 0",
          "step": "60s",
          "iconColor": "red",
          "textFormat": "Application Down",
          "tags": ["deployment"]
        }
      ]
    },
    "refresh": "30s",
    "schemaVersion": 27,
    "version": 1,
    "links": []
  }
}